{
  "manifest_version": 3,
  "name": "PrivacyGuard AI Protector",
  "version": "1.0",
  "description": "Prevents sensitive data leakage to LLMs.",
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://labs.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://notebooklm.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://you.com/*",
        "https://character.ai/*",
        "https://beta.character.ai/*",
        "https://pi.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://deepseek.com/*",
        "https://chat.deepseek.com/*",
        "https://mistral.ai/*",
        "https://chat.mistral.ai/*",
        "https://openrouter.ai/*",
        "https://phind.com/*",
        "https://huggingface.co/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://blackbox.ai/*",
        "https://www.blackbox.ai/*",
        "https://minimax.io/*",
        "https://www.minimax.io/*",
        "https://chat.minimax.io/*",
        "https://qwen.ai/*",
        "https://chat.qwen.ai/*",
        "https://chatglm.cn/*",
        "https://z.ai/*",
        "https://chat.z.ai/*",
        "https://moonshot.cn/*",
        "https://www.moonshot.cn/*",
        "https://kimi.moonshot.cn/*",
        "https://yuanbao.tencent.com/*",
        "https://hunyuan.tencent.com/*",
        "https://tongyi.aliyun.com/*",
        "https://yiyan.baidu.com/*",
        "https://xinghuo.xfyun.cn/*",
        "https://doubao.com/*",
        "https://www.doubao.com/*",
        "https://coze.com/*",
        "https://www.coze.com/*",
        "https://cohere.com/*",
        "https://www.cohere.com/*",
        "https://coral.cohere.com/*",
        "https://reka.ai/*",
        "https://www.reka.ai/*",
        "https://forefront.ai/*",
        "https://www.forefront.ai/*",
        "https://ora.ai/*",
        "https://www.ora.ai/*",
        "https://lmarena.ai/*",
        "https://www.lmarena.ai/*",
        "https://t3.chat/*",
        "https://chat.t3.chat/*",
        "https://duck.ai/*",
        "https://jasper.ai/*",
        "https://www.jasper.ai/*",
        "https://chat.suno.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}

